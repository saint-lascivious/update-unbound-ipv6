[Unit]
Description=Executes unbound-ipv6-update periodically.
Documentation=man:systemd.timer(5)
Requires=update-unbound-ipv6.service

[Timer]
OnBootSec=2min

OnCalendar=hourly
Persistent=true

RandomizedDelaySec=5min
AccuracySec=1min

Unit=unbound-ipv6-update.service

[Install]
WantedBy=timers.target
